// Prisma schema - baza de date Neon Postgres (cloud)
// Documentatie: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String
  passwordHash String
  createdAt    DateTime  @default(now())

  listings     Listing[]
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Int      // pret in RON (intreg, fara zecimale)
  category    String
  location    String
  imageUrl    String?  // URL Vercel Blob

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}
